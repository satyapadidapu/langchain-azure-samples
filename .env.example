# Microsoft Foundry credentials
# Get these from: https://ai.azure.com → Your project → Settings → Endpoints & Keys

# Required for all samples
AZURE_AI_PROJECT_ENDPOINT=https://<your-resource>.services.ai.azure.com/api/projects/<your-project>
AZURE_AI_API_KEY=<your-api-key>
MODEL_DEPLOYMENT_NAME=gpt-4.1

# Required for RAG samples (embeddings)
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/openai/v1

# Optional (defaults shown)
EMBEDDING_MODEL=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-06-01

# Claude model (for langchain-claude-opus-version1)
AZURE_ANTHROPIC_ENDPOINT=https://<your-resource>.services.ai.azure.com/anthropic/v1
CLAUDE_MODEL_NAME=claude-opus-4-6
